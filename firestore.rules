rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if the user is signed in
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Helper function to check if a document exists in the users collection
    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }
    
    // Helper function to get user data from the users collection
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    // Helper function to check if the user has either admin or operator role
    function isStaffOrAdmin() {
      return isSignedIn() && userExists(request.auth.uid) && (getUserData().role == 'operator' || getUserData().role == 'admin');
    }

    // Rules for users collection
    match /users/{userId} {
      // Allow reading if signed in
      allow read: if isSignedIn();
      
      // Allow creation only if it's the user's own document, and they default their role to 'operator'
      allow create: if isSignedIn() && request.auth.uid == userId 
                    && request.resource.data.role == 'operator'
                    && request.resource.data.email is string
                    && request.resource.data.name is string;
      
      // Allow update of own document (excluding role), or full update if admin
      allow update: if isSignedIn() && (
        (request.auth.uid == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) 
        || (userExists(request.auth.uid) && getUserData().role == 'admin')
      );
      
      // Only admin can delete users
      allow delete: if isSignedIn() && userExists(request.auth.uid) && getUserData().role == 'admin';
    }
    
    // Rules for transactions (pemasukan, pengeluaran, utang_piutang)
    
    match /pemasukan/{id} {
      allow read: if isStaffOrAdmin();
      
      allow create: if isStaffOrAdmin() 
                    && request.resource.data.created_by == request.auth.uid
                    && request.resource.data.tanggal is timestamp
                    && request.resource.data.cash is int
                    && request.resource.data.transfer_bca is int
                    && request.resource.data.qris_dana is int
                    && request.resource.data.denda is int
                    && request.resource.data.kerusakan is int
                    && request.resource.data.dp is int
                    && request.resource.data.total_pemasukan is int;
                    
      // Admin & Operator bisa update
      allow update: if isStaffOrAdmin()
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['created_by']);
                    
      // Hanya Admin yang bisa delete
      allow delete: if isSignedIn() && userExists(request.auth.uid) && getUserData().role == 'admin';
    }
    
    match /pengeluaran/{id} {
      allow read: if isStaffOrAdmin();
      
      allow create: if isStaffOrAdmin() 
                    && request.resource.data.created_by == request.auth.uid
                    && request.resource.data.nama_barang is string
                    && request.resource.data.kategori is string
                    && request.resource.data.nominal is int
                    && request.resource.data.tanggal is timestamp;
                    
      // Admin & Operator bisa update
      allow update: if isStaffOrAdmin()
                    && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['created_by']);
                    
      // Hanya Admin yang bisa delete
      allow delete: if isSignedIn() && userExists(request.auth.uid) && getUserData().role == 'admin';
    }
    
    match /utang_piutang/{id} {
      allow read: if isStaffOrAdmin();
      
      // Create - validasi field wajib
      allow create: if isStaffOrAdmin() 
                    && request.resource.data.created_by == request.auth.uid
                    && request.resource.data.nama_customer is string
                    && request.resource.data.tipe is string
                    && (request.resource.data.tipe == 'utang' || request.resource.data.tipe == 'piutang');
                    
      // Update - Admin & Operator bisa update semua field kecuali created_by
      // Lebih fleksibel untuk support berbagai field (status, pembayaran, dll)
      allow update: if isStaffOrAdmin()
                    && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['created_by']) 
                        || !('created_by' in resource.data));
                    
      // Hanya Admin yang bisa delete
      allow delete: if isSignedIn() && userExists(request.auth.uid) && getUserData().role == 'admin';
    }
    
    // Rules untuk collection utang (jika terpisah)
    match /utang/{id} {
      allow read: if isStaffOrAdmin();
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin();
      allow delete: if isSignedIn() && userExists(request.auth.uid) && getUserData().role == 'admin';
    }
    
    // Rules untuk collection piutang (jika terpisah)
    match /piutang/{id} {
      allow read: if isStaffOrAdmin();
      allow create: if isStaffOrAdmin();
      allow update: if isStaffOrAdmin();
      allow delete: if isSignedIn() && userExists(request.auth.uid) && getUserData().role == 'admin';
    }
  }
}
